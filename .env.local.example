# Google Sheets published CSV URLs
# File → Share → Publish to web → select the tab → CSV → Copy link
NEXT_PUBLIC_SHEET_INDIVIDUAL_URL=
NEXT_PUBLIC_SHEET_TEAM_URL=

# Event configuration
NEXT_PUBLIC_EVENT_NAME=85SIXTY Space Camp

# Update this each morning to the current day (Monday, Tuesday, Wednesday, Thursday, Friday)
NEXT_PUBLIC_CURRENT_DAY=Monday

# Team names — must exactly match the 'team' column values in your Google Sheet
NEXT_PUBLIC_TEAM_1=Team Alpha
NEXT_PUBLIC_TEAM_2=Team Bravo
NEXT_PUBLIC_TEAM_3=Team Charlie
NEXT_PUBLIC_TEAM_4=Team Delta

# Team accent colors (hex)
NEXT_PUBLIC_TEAM_1_COLOR=#6366F1
NEXT_PUBLIC_TEAM_2_COLOR=#EC4899
NEXT_PUBLIC_TEAM_3_COLOR=#10B981
NEXT_PUBLIC_TEAM_4_COLOR=#F59E0B
